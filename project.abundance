    {
      "atomType": "GitHubMolecule",
      "x": 0.802734375,
      "y": 0.36904761904761907,
      "uniqueID": "id-22244",
      "name": "crv.OpenWireLoft",
      "ioValues": [
        {
          "name": "Wires",
          "ioValue": "__GEOMETRY_INPUT__"
        },
        {
          "name": "Thickness",
          "ioValue": 0
