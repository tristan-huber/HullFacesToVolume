 \"dd\": 23.172268310150542       },       {         \"k\": 0,         \"n\": 184.72228855281685,         \"dd\": 6.707857800768579       },       {         \"k\": 0,         \"n\": 259.99087544230673,         \"dd\": 0       }     ],     [       {         \"k\": 0,         \"n\": 0,         \"dd\": 0       },       {         \"k\": 0,         \"n\": 3.590386873715886,         \"dd\": 98.22239937720362       },       {         \"k\": 1,         \"n\": 5.907469910460634,         \"dd\": 41.710058435217135       },       {         \"k\": 0,         \"n\": 19.81081529097125,         \"dd\": 4.634489331926602       },       {         \"k\": 0,         \"n\": 59.20380183628629,         \"dd\": 76.46843303333631       },       {         \"k\": 0,         \"n\": 124.08596137901407,         \"dd\": 41.710080728902454       },       {         \"k\": 0,         \"n\": 124.08596137901407,         \"dd\": 0       }     ],     [       {         \"k\": 0,         \"n\": 0,         \"dd\": 0       },       {         \"k\": 0,         \"n\": -13.222641139835503,         \"dd\": 57.90226304685915       },       {         \"k\": 0,         \"n\": -14.871515546526226,         \"dd\": 42.869341218626346       },       {         \"k\": 0,         \"n\": -13.222641139835503,         \"dd\": 34.62523670939656       },       {         \"k\": 0,         \"n\": -4.978581217976355,         \"dd\": 36.27407767555931       },       {         \"k\": 0,         \"n\": 237.62986319405695,         \"dd\": 56.31614536434026       },       {         \"k\": 0,         \"n\": 237.62986319405695,         \"dd\": 0       }     ]   ],   \"waterline\": 150,   \"deckRakeDeg\": 0 }"
