      "interpreterVersion": 1,
      "code": "function run(faces: Assembly, thickness: number = 1) {\n  const resultLeafs = []\n  faces.onLeafs((leaf) => {\n    if (leaf.geometry instanceof replicad.Face) {\n      console.log(\"is face\")\n      const result = faceThicken(leaf.geometry, thickness)\n      if (result == undefined) {\n        leaf.tags.push(\"FAILED_OFFSET\")\n        return leaf;\n      }\n      leaf.geometry = result;\n      return leaf;\n    } else if (leaf.is3D()) {\n      for (const face of leaf.geometry.faces) {\n        const res = faceThicken(face, thickness)\n        if (res == undefined) {\n          resultLeafs.push(new Assembly({\n            ...leaf,\n            tags: [...leaf.tags, \"FAILED_OFFSET\"]\n          }))\n        } else {\n          const r = new Assembly(leaf)\n          r.geometry = res;\n          resultLeafs.push(r);\n        }\n      }\n      return leaf;\n    } else {\n      throw Error(\"input must be faces or other 3dshape.\")\n    }\n  });\n  return resultLeafs;\n}\n\nfunction faceThicken(face: replicad.Face, thickness: number) {\n  if (thickness != 0) {\n    try {\n      return replicad.makeOffset(face, thickness);\n    } catch (e) {\n      console.warn(\"failed to thicken a face\")\n      console.error(e)\n      return undefined;\n    }\n  }\n  console.log('thickness was zero')\n  return face\n}",
      "compiledCode": "\"use strict\";\nfunction run(faces, thickness = 1) {\n    const resultLeafs = [];\n    faces.onLeafs((leaf) => {\n        if (leaf.geometry instanceof replicad.Face) {\n            console.log(\"is face\");\n            const result = faceThicken(leaf.geometry, thickness);\n            if (result == undefined) {\n                leaf.tags.push(\"FAILED_OFFSET\");\n                return leaf;\n            }\n            leaf.geometry = result;\n            return leaf;\n        }\n        else if (leaf.is3D()) {\n            for (const face of leaf.geometry.faces) {\n                const res = faceThicken(face, thickness);\n                if (res == undefined) {\n                    resultLeafs.push(new Assembly({\n                        ...leaf,\n                        tags: [...leaf.tags, \"FAILED_OFFSET\"]\n                    }));\n                }\n                else {\n                    const r = new Assembly(leaf);\n                    r.geometry = res;\n                    resultLeafs.push(r);\n                }\n            }\n            return leaf;\n        }\n        else {\n            throw Error(\"input must be faces or other 3dshape.\");\n        }\n    });\n    return resultLeafs;\n}\nfunction faceThicken(face, thickness) {\n    if (thickness != 0) {\n        try {\n            return replicad.makeOffset(face, thickness);\n        }\n        catch (e) {\n            console.warn(\"failed to thicken a face\");\n            console.error(e);\n            return undefined;\n        }\n    }\n    console.log('thickness was zero');\n    return face;\n}\n"
    },
    {
      "atomType": "Code",
      "x": 0.20572916666666666,
      "y": 0.5485714285714286,
      "uniqueID": "id-22023",
      "ioValues": [
        {
          "name": "faces",
