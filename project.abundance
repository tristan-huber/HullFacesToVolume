    {
      "atomType": "Code",
      "x": 0.38476562500000006,
      "y": 0.4464285714285714,
      "uniqueID": "id-22265",
      "ioValues": [
        {
          "name": "surface",
          "ioValue": "__GEOMETRY_INPUT__"
        },
        {
          "name": "numRulings",
