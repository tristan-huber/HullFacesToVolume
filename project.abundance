      ],
      "interpreterVersion": 1,
      "code": "\nfunction run(\n  wires: Assembly\n) {\n  const wireList: replicad.Wire[] = []\n  wires.onLeafs((leaf) => {\n    if (!(leaf.geometry instanceof replicad.Wire)) {\n      throw new Error(\"Only wire type inputs allowed\")\n    }\n    wireList.push(leaf.geometry)\n    return leaf;\n  })\n  // stitching pass.\n  const stitchedEdges = []\n  for (let i = 0; i < wireList.length; i++) {\n    stitchedEdges.push(wireList[i])\n    const end = wireList[i].endPoint\n    const start = wireList[(i + 1) % wireList.length].startPoint\n    if (!start.equals(end)){\n      stitchedEdges.push(replicad.makeLine(end, start))\n    }\n  }\n\n  return replicad.makeNonPlanarFace(replicad.assembleWire(stitchedEdges))\n}\n/*\n  const surfaces = [];\n  const leadFaceEdges = [];\n  const endFaceEdges = [];\n  for (let i = 0; i < wireList.length; i++) {\n    const w1 = wireList[i]\n    const w2 = wireList[(i + 1) % wireList.length]\n    const surf = replicad.loft([w1, w2], {}, true)\n    surfaces.push(surf)\n    leadFaceEdges.push(replicad.makeLine(w1.startPoint, w2.startPoint))\n    endFaceEdges.push(replicad.makeLine(w1.endPoint, w2.endPoint))\n  }\n  const frontCap = replicad.makeNonPlanarFace(replicad.assembleWire(leadFaceEdges))\n  const endCap = replicad.makeNonPlanarFace(replicad.assembleWire(endFaceEdges))\n\n  return replicad.makeSolid([frontCap, ...surfaces, endCap])*/",
      "compiledCode": "\"use strict\";\nfunction run(wires) {\n    const wireList = [];\n    wires.onLeafs((leaf) => {\n        if (!(leaf.geometry instanceof replicad.Wire)) {\n            throw new Error(\"Only wire type inputs allowed\");\n        }\n        wireList.push(leaf.geometry);\n        return leaf;\n    });\n    // stitching pass.\n    const stitchedEdges = [];\n    for (let i = 0; i < wireList.length; i++) {\n        stitchedEdges.push(wireList[i]);\n        const end = wireList[i].endPoint;\n        const start = wireList[(i + 1) % wireList.length].startPoint;\n        if (!start.equals(end)) {\n            stitchedEdges.push(replicad.makeLine(end, start));\n        }\n    }\n    return replicad.makeNonPlanarFace(replicad.assembleWire(stitchedEdges));\n}\n/*\n  const surfaces = [];\n  const leadFaceEdges = [];\n  const endFaceEdges = [];\n  for (let i = 0; i < wireList.length; i++) {\n    const w1 = wireList[i]\n    const w2 = wireList[(i + 1) % wireList.length]\n    const surf = replicad.loft([w1, w2], {}, true)\n    surfaces.push(surf)\n    leadFaceEdges.push(replicad.makeLine(w1.startPoint, w2.startPoint))\n    endFaceEdges.push(replicad.makeLine(w1.endPoint, w2.endPoint))\n  }\n  const frontCap = replicad.makeNonPlanarFace(replicad.assembleWire(leadFaceEdges))\n  const endCap = replicad.makeNonPlanarFace(replicad.assembleWire(endFaceEdges))\n\n  return replicad.makeSolid([frontCap, ...surfaces, endCap])*/ \n"
